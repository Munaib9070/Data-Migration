        <client_script><![CDATA[api.controller = function($location){

  var c = this;

  c.cid = sessionStorage.getItem('currentId');

  c.isActive = function(page){
    return $location.search().id === page;
  };

  c.getCartCount = function(){
    var cart = JSON.parse(sessionStorage.getItem("migration_cart") || "[]");
    return cart.length;
  };

};]]></client_script>
        <controller_as>c</controller_as>
        <css>*{
  outline-style:none!important;
}

.dm-sidebar{
  width:100%;
  height:calc(100vh - 64px);
  background:#fff;
  border-right:1px solid #edf0f5;
  padding:22px 14px;
}

.dm-menu{
  list-style:none;
  padding:0;
  margin:0;
  display:flex;
  flex-direction:column;
  gap:8px;
}

.dm-menu a{
  display:flex;
  align-items:center;
  padding:10px 12px;
  border-radius:16px;
  text-decoration:none;
  font-size:15px;
  font-weight:500;
  color:#3b4455;
  transition:all .25s ease;
}

.dm-menu a:focus,
.dm-menu a:active,
.dm-menu a:focus-visible {
  outline: none !important;
  box-shadow: none !important;
}

.dm-icon-box{
  width:36px;
  height:36px;
  border-radius:11px;
  background:#f5f7fb;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-right:13px;
  flex-shrink:0;
}

.dm-icon-box svg{
  width:17px;
  height:17px;
  stroke:#1F8C95;
  stroke-width:1.7;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.dm-text{
  flex:1;
  line-height:1.25;
}

.dm-right{
  display:flex;
  align-items:center;
  gap:10px;
}

.dm-arrow{
  width:16px;
  height:16px;
  stroke:#1F8C95;
  stroke-width:2;
  opacity:0;
  visibility:hidden;
  flex-shrink:0;
  transition:all .2s ease;
}

.cart-badge{
  background:#1F8C95;
  color:#fff;
  font-size:11px;
  min-width:20px;
  height:20px;
  border-radius:4px;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:0 6px;
}
.cart-li.active .cart-badge{
	background: #fff;
  color:#000;
}
.cart-li:hover .cart-badge{
  background: #fff;
  color:#000;
}
.dm-menu li:not(.active) a:hover{
  background:#1F8C95;
  color:#fff;
}

.dm-menu li.active a{
   background: linear-gradient(to right, #128a9a, #0a5f6d);

  transition: all 2s ease-out;
  color:#fff;
  box-shadow:0 8px 22px rgba(37,99,235,.22);
}

.dm-menu li.active .dm-icon-box{
  background:rgba(255,255,255,.15);
}

.dm-menu li.active .dm-icon-box svg{
  stroke:#fff;
}

.dm-menu li.active .dm-arrow{
  opacity:1;
  visibility:visible;
  stroke:#fff;
}</css>
